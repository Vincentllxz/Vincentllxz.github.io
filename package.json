{
  "name": "astro-theme-pure",
  "type": "module",
  "version": "4.0.9",
  "scripts": {
    "dev": "astro dev",
    "dev:check": "astro check --watch & astro dev",
    "build": "astro-pure check && astro check && astro build",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check",
    "astro": "astro",
    "pure": "astro-pure",
    "new": "astro-pure new",
    "format": "prettier --write  '**/*.{js,jsx,ts,tsx,md,mdx,astro}'",
    "lint": "eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "yijiansilian": "bun lint && bun sync && bun check && bun format",
    "clean": "rm -rf .astro .vercel dist",
    "cache:avatars": "tsx scripts/cacheAvatars.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/vercel": "^9.0.4",
    "@waline/client": "^3.7.1",
    "astro": "^5.17.2",
    "astro-og-canvas": "^0.11.1",
    "astro-pure": "1.3.6",
    "katex": "^0.16.25",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "eslint-plugin-astro": "^1.5.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1"
  },
  "//overrides": "astro-pure targets zod v3; pin zod tree-wide to one v3 build so a hoisted zod v4 can't reach it (a v3/v4 cross-instance schema merge crashes the astro-pure config hook). zod 3.25.x still exposes the v4 API at `zod/v4` for any v4-only consumer.",
  "overrides": {
    "zod": "3.25.76"
  }
}
