---
// A numbered chapter index with a progress bar, for course-note table-of-contents pages.
// Chapters without an `href` render as muted "整理中" (work-in-progress) rows.
interface Chapter {
  n: number
  title: string
  href?: string
}

interface Props {
  chapters: Chapter[]
}

const { chapters } = Astro.props
const done = chapters.filter((c) => c.href).length
const total = chapters.length
const pct = total > 0 ? Math.round((done / total) * 100) : 0
---

<div class='not-prose my-7'>
  {/* Progress summary */}
  <div class='mb-5 rounded-2xl border bg-card p-4 sm:p-5'>
    <div class='flex items-baseline justify-between'>
      <span class='text-sm font-semibold text-foreground'>章節進度</span>
      <span class='text-sm text-muted-foreground'>{done} / {total} 章</span>
    </div>
    <div class='mt-3 h-2 overflow-hidden rounded-full bg-muted'>
      <div class='h-full rounded-full bg-primary' style={`width:${pct}%`}></div>
    </div>
  </div>

  {/* Chapter rows */}
  <ol class='flex flex-col gap-2.5'>
    {
      chapters.map((c) => {
        const Element = c.href ? 'a' : 'div'
        return (
          <li>
            <Element
              href={c.href}
              data-astro-prefetch={c.href ? true : undefined}
              class:list={[
                'group flex items-center gap-4 rounded-2xl border px-4 py-3 transition-all',
                c.href
                  ? 'bg-background hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md hover:shadow-primary/10'
                  : 'bg-muted/40 opacity-70'
              ]}
            >
              <span
                class:list={[
                  'flex size-9 shrink-0 items-center justify-center rounded-xl text-sm font-semibold',
                  c.href ? 'bg-primary/10 text-primary' : 'bg-muted text-muted-foreground'
                ]}
              >
                {c.n}
              </span>
              <span
                class:list={[
                  'min-w-0 grow truncate font-medium',
                  c.href ? 'text-foreground group-hover:text-primary' : 'text-muted-foreground'
                ]}
              >
                {c.title}
              </span>
              {
                c.href ? (
                  <span class='shrink-0 text-muted-foreground transition-transform group-hover:translate-x-1'>
                    →
                  </span>
                ) : (
                  <span class='shrink-0 rounded-full border px-2 py-0.5 text-[11px] font-medium text-muted-foreground'>
                    整理中
                  </span>
                )
              }
            </Element>
          </li>
        )
      })
    }
  </ol>
</div>
