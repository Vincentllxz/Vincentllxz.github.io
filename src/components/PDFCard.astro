---
interface Props {
  title: string
  subtitle?: string
  href?: string
  /** Legacy aliases (older blog posts pass these instead of subtitle/href). */
  description?: string
  link?: string
  /** Course shorthand drawn large in the window, e.g. `ADA`, `OS`. */
  abbr?: string
  /** Accent color as an hsl triple `H S% L%`, e.g. `'217 85% 54%'`. */
  accent?: string
  /** `pdf` opens a PDF file in a new tab; `note` links to an in-site notes page. */
  type?: 'pdf' | 'note'
}

const props = Astro.props
const { title, type = 'pdf' } = props
const subtitle = props.subtitle ?? props.description
const href = props.href ?? props.link ?? '#'
const isPdf = type === 'pdf'
const badgeLabel = isPdf ? 'PDF' : 'NOTE'
const ctaLabel = isPdf ? 'open_pdf' : 'open_note'

// Window shorthand: short first word, otherwise up-to-3 initials.
const words = title.split(/\s+/)
const abbr =
  props.abbr ??
  ((words[0] ?? '').length <= 5
    ? (words[0] ?? '')
    : words
        .map((w) => w[0])
        .join('')
        .slice(0, 3)
        .toUpperCase())
const accent = props.accent ?? '193 70% 50%'
const filename = `${abbr}.${isPdf ? 'pdf' : 'note'}`
---

<a
  href={href}
  target={isPdf ? '_blank' : undefined}
  rel={isPdf ? 'noreferrer' : undefined}
  data-astro-prefetch={isPdf ? undefined : true}
  class='pdfcard group not-prose block overflow-hidden rounded-xl border bg-card font-mono shadow-sm transition-all duration-300 hover:-translate-y-1'
  style={`--ac: ${accent}`}
>
  {/* 視窗條：交通燈 + 檔名頁籤 + 類型徽章 */}
  <div
    class='pdfcard-titlebar flex items-center gap-2 border-b px-4 py-2.5'
  >
    <span class='pdfcard-dots flex items-center gap-1.5' aria-hidden='true'>
      <span class='pdfcard-dot'></span>
      <span class='pdfcard-dot'></span>
      <span class='pdfcard-dot'></span>
    </span>
    <span class='pdfcard-filename flex-1 truncate text-center text-xs text-muted-foreground'>
      {filename}
    </span>
    <span class='pdfcard-badge text-[11px] font-semibold tracking-wide'>
      [{badgeLabel}]
    </span>
  </div>

  {/* 視窗內文 */}
  <div class='pdfcard-body relative space-y-2 p-5'>
    <span class='pdfcard-abbr' aria-hidden='true'>{abbr}</span>
    <h3 class='break-words text-lg font-semibold leading-snug text-foreground transition-colors'>
      {title}
    </h3>
    {subtitle && <p class='break-words text-sm text-muted-foreground'>{subtitle}</p>}
    <div class='pdfcard-cta flex items-center pt-2 text-sm'>
      <span class='pdfcard-prompt mr-2 select-none'>&gt;</span>
      <span>{ctaLabel}</span>
      <span class='pdfcard-cursor' aria-hidden='true'></span>
    </div>
  </div>
</a>

<style>
  .pdfcard {
    --accent: hsl(var(--ac));
  }
  /* Lift the accent in dark mode so mid-lightness hues stay readable. */
  :global(html.dark) .pdfcard {
    --accent: color-mix(in srgb, hsl(var(--ac)), white 22%);
  }
  .pdfcard:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    box-shadow: 0 14px 36px -14px color-mix(in srgb, var(--accent) 38%, transparent);
  }
  .pdfcard:hover h3 {
    color: var(--accent);
  }

  /* === Window chrome === */
  .pdfcard-titlebar {
    background: color-mix(in srgb, var(--accent) 6%, hsl(var(--muted)));
  }
  .pdfcard-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 9999px;
    background: hsl(var(--muted-foreground) / 0.35);
    transition:
      background 0.3s ease,
      transform 0.3s ease;
  }
  .pdfcard:hover .pdfcard-dot:nth-child(1) {
    background: #ff5f56;
  }
  .pdfcard:hover .pdfcard-dot:nth-child(2) {
    background: #ffbd2e;
  }
  .pdfcard:hover .pdfcard-dot:nth-child(3) {
    background: #27c93f;
  }
  .pdfcard-badge,
  .pdfcard-prompt {
    color: var(--accent);
  }

  /* === Window body: faint accent glow + big shorthand === */
  .pdfcard-body::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 130% at 92% 0%, hsl(var(--ac) / 0.12), transparent 60%);
    pointer-events: none;
  }
  .pdfcard-abbr {
    display: block;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.01em;
    color: var(--accent);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pdfcard:hover .pdfcard-abbr {
    transform: translateX(4px);
  }

  /* === Command-line CTA with blinking cursor === */
  .pdfcard-cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    margin-left: 0.15em;
    transform: translateY(0.12em);
    background: var(--accent);
    animation: pdfcard-blink 1.1s step-end infinite;
  }
  @keyframes pdfcard-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pdfcard-cursor {
      animation: none;
      opacity: 0.8;
    }
  }
</style>
