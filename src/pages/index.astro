---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, FormattedDate, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import avatar from '@/assets/avatar.png'
import config from '@/site-config'

const languages = ['C', 'C++', 'Python']
const frontend = ['TypeScript', 'Vite', 'Webpack', 'Astro']
const backend = ['Vercel', 'Waline']

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

// Course-note series (e.g. `sp`) live in their own collection; surface their index here.
const noteSeries = ((await getBlogCollection('notes')) as CollectionEntry<'notes'>[])
  .filter((note) => !note.id.includes('/'))
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())

// JSON-LD: identify the site + author as schema.org entities (knowledge-graph).
const siteHref = Astro.site?.href ?? 'https://vinsong.csie.org/'
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': siteHref + '#website',
      url: siteHref,
      name: config.title,
      description: config.description,
      inLanguage: config.locale.lang,
      publisher: { '@id': siteHref + '#person' }
    },
    {
      '@type': 'Person',
      '@id': siteHref + '#person',
      name: config.author,
      url: siteHref,
      sameAs: ['https://github.com/Vincentllxz', 'https://www.instagram.com/vincent_hu313_/']
    }
  ]
}
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#5BBCD6'>
  <link rel='preconnect' href='https://fonts.googleapis.com' />
  <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
  <link rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap' />
  <script
    type='application/ld+json'
    set:html={JSON.stringify(structuredData).replace(/</g, '\\u003c')}
  />

  <main class='home-main flex w-full flex-col items-center'>
    <div class='home-intro-backdrop' aria-hidden='true'></div>
    <div class='home-whoami' aria-hidden='true'>
      <span class='home-whoami-text'></span><span class='home-whoami-caret'></span>
    </div>
    <div class='home-scroll-hint' aria-hidden='true'>
      <span class='home-scroll-label'>scroll</span>
      <svg
        class='home-scroll-chevron'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2.5'
        stroke-linecap='round'
        stroke-linejoin='round'
      >
        <path d='M6 9l6 6 6-6'></path>
      </svg>
    </div>
    <section class='animate relative mb-10 flex flex-col items-center gap-y-4' id='content-header'>
      <div class='home-codes' aria-hidden='true'>
        <span class='home-code home-code-l'>{`{ }`}</span>
        <span class='home-code home-code-r'>&gt;<span class='home-code-caret'>_</span></span>
      </div>
      <div class='home-signature' aria-label='VinSong'>
        <div class='home-signature-tilt'>
          <svg class='home-signature-svg' viewBox='0 0 560 180' role='img' aria-label='VinSong'>
            <text x='50%' y='126' text-anchor='middle' class='home-signature-text'>VinSong</text>
          </svg>
          <svg
            class='home-signature-svg home-signature-glow-svg'
            viewBox='0 0 560 180'
            aria-hidden='true'
          >
            <defs>
              <linearGradient id='sig-ink' x1='0%' y1='0%' x2='100%' y2='100%'>
                <stop offset='0%' stop-color='#a8dcea'></stop>
                <stop offset='55%' stop-color='#b3c4f2'></stop>
                <stop offset='100%' stop-color='#d9bdee'></stop>
              </linearGradient>
            </defs>
            <text
              x='50%'
              y='126'
              text-anchor='middle'
              class='home-signature-text home-signature-glow-text'>VinSong</text
            >
          </svg>
        </div>
      </div>

      <script is:inline>
        ;(() => {
          try {
            const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
            const main = document.querySelector('.home-main')
            const sig = document.querySelector('.home-signature')
            const tilt = document.querySelector('.home-signature-tilt')
            const glow = document.querySelector('.home-signature-glow-svg')
            if (!main || !sig) return

            // Ink glow + magnetic 3D tilt: the signature reacts to the pointer
            // both on the cover and after entering the page.
            if (!reduced && tilt && glow) {
              let tx = 0
              let ty = 0
              let cx = 0
              let cy = 0
              let raf = 0
              const step = () => {
                cx += (tx - cx) * 0.12
                cy += (ty - cy) * 0.12
                tilt.style.transform =
                  'rotateX(' + cy.toFixed(2) + 'deg) rotateY(' + cx.toFixed(2) + 'deg)'
                raf = Math.abs(tx - cx) + Math.abs(ty - cy) > 0.02 ? requestAnimationFrame(step) : 0
              }
              const onPointer = (e) => {
                const r = sig.getBoundingClientRect()
                const pad = 90
                if (
                  e.clientX > r.left - pad &&
                  e.clientX < r.right + pad &&
                  e.clientY > r.top - pad &&
                  e.clientY < r.bottom + pad
                ) {
                  tx = ((e.clientX - (r.left + r.width / 2)) / (r.width / 2)) * 7
                  ty = ((r.top + r.height / 2 - e.clientY) / (r.height / 2)) * 6
                  // Percentages stay correct even while the gate scales the signature.
                  glow.style.setProperty(
                    '--mx',
                    (((e.clientX - r.left) / r.width) * 100).toFixed(1) + '%'
                  )
                  glow.style.setProperty(
                    '--my',
                    (((e.clientY - r.top) / r.height) * 100).toFixed(1) + '%'
                  )
                  glow.classList.add('glow-on')
                } else {
                  tx = 0
                  ty = 0
                  glow.classList.remove('glow-on')
                }
                if (!raf) raf = requestAnimationFrame(step)
              }
              window.addEventListener('pointermove', onPointer, { passive: true })
            }

            if (reduced) return
            const r = sig.getBoundingClientRect()
            if (!r.width || !r.height) return
            const vw = window.innerWidth
            const vh = window.innerHeight
            // Fit the signature to the site's content column (max-w-70rem + the
            // header's responsive padding) so its left edge lines up with the bar.
            const pad = vw >= 1024 ? 40 : vw >= 640 ? 28 : 16
            const containerW = Math.min(vw, 1120)
            const innerLeft = (vw - containerW) / 2 + pad
            const innerW = containerW - pad * 2
            const scale = Math.max(1.15, Math.min(innerW / r.width, (vh * 0.6) / r.height))
            sig.style.setProperty('--intro-tx', (vw / 2 - (r.left + r.width / 2)).toFixed(1) + 'px')
            sig.style.setProperty('--intro-ty', (vh / 2 - (r.top + r.height / 2)).toFixed(1) + 'px')
            sig.style.setProperty('--intro-scale', scale.toFixed(3))
            // Align the typed prompt with the content column's left edge (= the bar).
            main.style.setProperty('--wa-left', innerLeft.toFixed(1) + 'px')
            sig.style.position = 'relative'
            sig.style.zIndex = '9991'
            main.classList.add('intro')

            // Lock the page so the full-screen signature can't be scrolled away.
            const docEl = document.documentElement
            const prevOverflow = docEl.style.overflow
            docEl.style.overflow = 'hidden'

            let entered = false
            let touchY = 0
            const onWheel = (e) => {
              if (e.deltaY > 0) enter()
            }
            const onTouchStart = (e) => {
              touchY = e.touches[0].clientY
            }
            const onTouchMove = (e) => {
              if (touchY - e.touches[0].clientY > 24) enter()
            }
            const onKey = (e) => {
              if (['ArrowDown', 'PageDown', 'End', ' ', 'Spacebar'].indexOf(e.key) !== -1) enter()
            }
            const enter = () => {
              if (entered) return
              entered = true
              window.removeEventListener('wheel', onWheel)
              window.removeEventListener('touchstart', onTouchStart)
              window.removeEventListener('touchmove', onTouchMove)
              window.removeEventListener('keydown', onKey)
              docEl.style.overflow = prevOverflow
              // If the user scrolls before the signature has drawn, snap it in.
              if (!main.classList.contains('sig-go')) main.classList.add('sig-instant')
              main.classList.add('entering')
              window.setTimeout(() => {
                sig.style.removeProperty('z-index')
                sig.style.removeProperty('position')
                const backdrop = main.querySelector('.home-intro-backdrop')
                if (backdrop) backdrop.remove()
                const hint = main.querySelector('.home-scroll-hint')
                if (hint) hint.remove()
                const wa = main.querySelector('.home-whoami')
                if (wa) wa.remove()
              }, 1100)
            }

            // Opening sequence: type `vinsong@blog:~$ whoami` top-left, then the
            // signature draws in the centre (as if it were whoami's answer).
            const waEl = main.querySelector('.home-whoami')
            const waText = waEl && waEl.querySelector('.home-whoami-text')
            const PROMPT = 'vinsong@blog:~$ '
            const FULL = PROMPT + 'whoami'
            let ti = 0
            const typeStep = () => {
              if (entered) return
              ti++
              if (waText) {
                const ps = FULL.slice(0, Math.min(ti, PROMPT.length))
                const cmd = ti > PROMPT.length ? FULL.slice(PROMPT.length, ti) : ''
                waText.innerHTML =
                  '<span class="wa-ps">' + ps + '</span><span class="wa-cmd">' + cmd + '</span>'
              }
              if (ti < FULL.length) {
                window.setTimeout(typeStep, 48)
              } else {
                window.setTimeout(() => {
                  if (!entered) main.classList.add('sig-go')
                }, 300)
                window.setTimeout(() => {
                  if (!entered) main.classList.add('hint-go')
                }, 1700)
              }
            }
            window.setTimeout(typeStep, 320)

            window.addEventListener('wheel', onWheel, { passive: true })
            window.addEventListener('touchstart', onTouchStart, { passive: true })
            window.addEventListener('touchmove', onTouchMove, { passive: true })
            window.addEventListener('keydown', onKey)
          } catch (e) {
            /* no gate on failure — page stays in its normal state */
          }
        })()
      </script>

      <div class='home-avatar-wrap'>
        <span class='home-avatar-halo' aria-hidden='true'></span>
        <Image
          src={avatar}
          alt='profile'
          class='home-avatar relative h-28 w-auto rounded-full border p-1'
          loading='eager'
        />
      </div>

      <div class='flex flex-col items-center gap-y-4 home-hero-meta'>
        <h1 class='text-3xl font-bold'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='Taiwan / Taipei'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href='https://github.com/Vincentllxz' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>CS Student / Developer</p>
        <p class='text-muted-foreground'>
          我是 VinSong，本來其實都喜歡叫 Vincent
          的，但這名字好像太菜市場了一直被用掉，所以只好自己取一個別的名字。
          <br />
          <br />
          我很喜歡紀錄生活，無論是用文字、照片還是影片，只要能留下什麼，我就會想做做看。架設這個網站，其實最初只是心血來潮的想法，但希望未來能一直延續下去，把生活的點點滴滴、一點一滴的成長，都留在這裡，也分享給願意停下來看看的人。
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>
      {
        (allPostsByDate.length > 0 || noteSeries.length > 0) && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {noteSeries.map((note) => (
                <li class='post-preview group/card relative flex flex-col rounded-2xl border bg-background px-5 py-2.5 transition-colors ease-in-out hover:bg-muted'>
                  <a
                    class='group/link flex w-full flex-col transition-all hover:text-primary sm:flex-row'
                    href={`/notes/${note.id}`}
                    data-astro-prefetch
                  >
                    <FormattedDate
                      class='min-w-[95px] py-1 text-xs'
                      date={note.data.updatedDate ?? note.data.publishDate}
                    />
                    <div class='z-10 flex-grow'>
                      <div class='flex items-center justify-between gap-2'>
                        <span class='inline-flex items-center gap-2'>
                          <span class='rounded-md border px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-muted-foreground'>
                            Notes
                          </span>
                          {note.data.title}
                        </span>
                        <span class='shrink-0 text-muted-foreground transition-transform duration-300 group-hover/link:translate-x-1'>
                          →
                        </span>
                      </div>
                    </div>
                  </a>
                </li>
              ))}
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }

      <Section title='Education'>
        <Card
          as='a'
          heading='National Taiwan University'
          subheading='Computer Science & Information Engineering (Bachelor)'
          date='September 2024 - present'
          href='https://www.youtube.com/watch?v=dQw4w9WgXcQ'
        />
      </Section>

      <Section title='Skills'>
        <SkillLayout title='Languages' skills={languages} />
        <!-- <SkillLayout title='Frontend' skills={frontend} />
        <SkillLayout title='Backend' skills={backend} /> -->
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>

<style is:global>
  /* === Floating code-symbol decorations beside the hero === */
  .home-codes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    z-index: 0;
  }
  .home-code {
    position: absolute;
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', Menlo, Consolas, monospace;
    font-weight: 500;
    font-size: clamp(28px, 4.5vw, 44px);
    line-height: 1;
    color: hsl(var(--muted-foreground));
    opacity: 0;
    letter-spacing: 0.05em;
    user-select: none;
    animation:
      home-code-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.6s forwards,
      home-code-drift 7s ease-in-out 1.5s infinite;
  }
  .home-code-l {
    left: clamp(8px, 7vw, 70px);
    top: 18px;
  }
  .home-code-r {
    right: clamp(8px, 7vw, 70px);
    top: 28px;
    animation:
      home-code-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.8s forwards,
      home-code-drift-alt 8.5s ease-in-out 1.7s infinite;
  }
  .home-code-caret {
    display: inline-block;
    margin-left: 2px;
    animation: home-code-caret 1.05s steps(1, end) 1.5s infinite;
  }
  /* During the gate the code symbols stay hidden; they ride in after the scroll. */
  .home-main.intro .home-code {
    animation: none;
  }
  .home-main.intro.entering .home-code-l {
    animation:
      home-code-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.55s forwards,
      home-code-drift 7s ease-in-out 1.45s infinite;
  }
  .home-main.intro.entering .home-code-r {
    animation:
      home-code-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.7s forwards,
      home-code-drift-alt 8.5s ease-in-out 1.6s infinite;
  }

  @keyframes home-code-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 0.55;
      transform: translateY(0);
    }
  }
  @keyframes home-code-drift {
    0%,
    100% {
      transform: translateY(0) rotate(-2deg);
    }
    50% {
      transform: translateY(-10px) rotate(2deg);
    }
  }
  @keyframes home-code-drift-alt {
    0%,
    100% {
      transform: translateY(-2px) rotate(2deg);
    }
    50% {
      transform: translateY(-12px) rotate(-2deg);
    }
  }
  @keyframes home-code-caret {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  /* === "VinSong" signature above the avatar — clean single-ink writing === */
  .home-signature {
    display: block;
    line-height: 1;
    color: hsl(var(--foreground));
    /* push the signature clear of the avatar below it */
    margin-bottom: clamp(1.5rem, 4vw, 3rem);
    perspective: 900px;
  }
  /* Magnetic 3D tilt lives on an inner wrapper so it never fights the
     gate's translate/scale transform on .home-signature itself. */
  .home-signature-tilt {
    position: relative;
    will-change: transform;
  }
  .home-signature-svg {
    width: clamp(340px, 66vw, 620px);
    height: auto;
    display: block;
    overflow: visible;
  }
  .home-signature-text {
    font-family: 'Great Vibes', 'Caveat', 'Snell Roundhand', 'Apple Chancery', cursive;
    font-size: 132px;
    font-weight: 400;
    letter-spacing: 0.01em;
    fill: transparent;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    /* large enough to cover the longest contour of "VinSong" in Great Vibes */
    stroke-dasharray: 1400;
    stroke-dashoffset: 1400;
    animation:
      home-signature-draw 1s cubic-bezier(0.65, 0, 0.35, 1) 0.2s forwards,
      home-signature-fill 0.35s ease-out 1.15s forwards;
  }
  @keyframes home-signature-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes home-signature-fill {
    to {
      fill: currentColor;
    }
  }
  /* Gate-only duplicates: distinct names so adding `.sig-go` always (re)triggers
     the draw, even though the base rule already ran an identically-named
     animation before JS booted. */
  @keyframes home-siggo-draw {
    from {
      stroke-dashoffset: 1400;
    }
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes home-siggo-fill {
    from {
      fill: transparent;
    }
    to {
      fill: currentColor;
    }
  }

  /* Iridescent-ink layer, revealed through a cursor-following radial mask. */
  .home-signature-glow-svg {
    /* blue iridescent ink-glow removed per request */
    display: none;
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.45s ease-out;
    pointer-events: none;
    filter: drop-shadow(0 0 10px hsl(193 60% 75% / 0.35));
    -webkit-mask-image: radial-gradient(
      circle 150px at var(--mx, 50%) var(--my, 50%),
      #000 30%,
      transparent 78%
    );
    mask-image: radial-gradient(
      circle 150px at var(--mx, 50%) var(--my, 50%),
      #000 30%,
      transparent 78%
    );
  }
  .home-signature-glow-svg.glow-on {
    opacity: 1;
  }
  .home-signature-glow-text {
    fill: url(#sig-ink);
    fill-opacity: 0;
    stroke: url(#sig-ink);
    stroke-width: 1.7;
    animation:
      home-signature-draw 1s cubic-bezier(0.65, 0, 0.35, 1) 0.2s forwards,
      home-signature-glow-fill 0.35s ease-out 1.15s forwards;
  }
  @keyframes home-signature-glow-fill {
    to {
      fill-opacity: 1;
    }
  }

  /* Halo + floating avatar — main visual on /. */
  .home-avatar-wrap {
    position: relative;
    display: inline-grid;
    place-items: center;
    isolation: isolate;
  }
  .home-avatar {
    animation: home-float 6s ease-in-out infinite;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 1;
  }
  .home-avatar:hover {
    transform: scale(1.05) rotate(-2deg);
  }
  .home-avatar-halo {
    position: absolute;
    inset: -16px;
    border-radius: 9999px;
    background: conic-gradient(
      from 0deg,
      hsl(193 70% 62% / 0.6),
      hsl(205 82% 74% / 0) 30%,
      hsl(186 72% 54% / 0.6) 60%,
      hsl(193 70% 62% / 0) 90%,
      hsl(193 70% 62% / 0.6)
    );
    filter: blur(16px);
    opacity: 0.7;
    z-index: 0;
    animation:
      home-halo-spin 14s linear infinite,
      home-halo-pulse 5s ease-in-out infinite;
    pointer-events: none;
  }
  html.dark .home-avatar-halo {
    opacity: 0.85;
  }

  /* === Opening gate: signature draws full-screen, scrolling down reveals the page === */
  .home-intro-backdrop {
    display: none;
  }
  .home-main.intro .home-intro-backdrop {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 9990;
    /* Pure-black opening; scrolling fades it away to reveal the purple-black page. */
    background: #000;
    pointer-events: none;
  }
  /* Scrolled down → the cover fades away. */
  .home-main.intro.entering .home-intro-backdrop {
    animation: home-intro-fade 0.9s ease-out 0.1s forwards;
  }

  /* The signature lives inside #content-header, which carries the theme's
     `.animate` (fade-in-up ends on `transform: translateY(0)`, kept by
     fill-mode: forwards). That transform makes #content-header a stacking
     context, trapping the signature's z-index *below* the black backdrop —
     so it only appears once the cover fades on scroll. Neutralize it while
     the gate is up so the signature can paint above the cover. */
  .home-main.intro #content-header {
    opacity: 1;
    transform: none;
    animation: none;
  }

  /* During the gate the signature is held full-screen (JS-measured transform). */
  .home-main.intro .home-signature {
    transform-origin: 50% 50%;
    transform: translate(var(--intro-tx, 0px), var(--intro-ty, 0px)) scale(var(--intro-scale, 1));
    /* The cover is pure black regardless of theme, so the ink (currentColor)
       must be light or it draws black-on-black and never shows. */
    color: #f4f5f7;
  }
  /* While `whoami` is typing, hold the signature hidden (no draw, no fill). */
  .home-main.intro .home-signature-text,
  .home-main.intro .home-signature-glow-text {
    animation: none;
    stroke-dashoffset: 1400;
    fill: transparent;
  }
  /* whoami finished → draw the signature (fast). JS adds `.sig-go`. */
  .home-main.intro.sig-go .home-signature-text {
    animation:
      home-siggo-draw 1s cubic-bezier(0.65, 0, 0.35, 1) 0s forwards,
      home-siggo-fill 0.35s ease-out 1s forwards;
  }
  /* Scrolled before the draw played → snap it in, filled. */
