<style>
  /* Cursive "VinSong" signature — mirrors the homepage hero's draw-then-fill. */
  .about-signature {
    display: block;
    margin: 0 auto 2.5rem;
    text-align: center;
    color: hsl(var(--foreground));
  }
  .about-signature-svg {
    width: clamp(280px, 50vw, 480px);
    height: auto;
    display: block;
    margin: 0 auto;
    overflow: visible;
  }
  .about-signature-text {
    font-family: 'Great Vibes', 'Caveat', 'Snell Roundhand', 'Apple Chancery', cursive;
    font-size: 132px;
    font-weight: 400;
    letter-spacing: 0.01em;
    fill: transparent;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    /* large enough to cover the longest contour of "VinSong" in Great Vibes */
    stroke-dasharray: 1400;
    stroke-dashoffset: 1400;
    animation:
      about-signature-draw 2s cubic-bezier(0.65, 0, 0.35, 1) 0.25s forwards,
      about-signature-fill 0.55s ease-out 2.05s forwards;
  }
  @keyframes about-signature-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes about-signature-fill {
    to {
      fill: currentColor;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .about-signature-text {
      animation: none;
      fill: currentColor;
      stroke-dashoffset: 0;
    }
  }
</style>
