<style>
  /* Compact cursive "VinSong" — serves as the name inside the profile card.
     inline-block makes it follow the card's text-align (centered on mobile,
     left-aligned from md up). */
  .about-signature {
    display: inline-block;
    margin: 0.1rem 0 0.35rem;
    color: hsl(var(--foreground));
    perspective: 900px;
  }
  /* Magnetic 3D tilt lives on an inner wrapper; inline-block keeps it sized to
     the signature so the glow mask coordinates stay correct. */
  .about-signature-tilt {
    position: relative;
    display: inline-block;
    will-change: transform;
  }
  .about-signature-svg {
    width: clamp(190px, 42vw, 270px);
    height: auto;
    display: block;
    overflow: visible;
  }
  .about-signature-text {
    font-family: 'Great Vibes', 'Caveat', 'Snell Roundhand', 'Apple Chancery', cursive;
    font-size: 132px;
    font-weight: 400;
    letter-spacing: 0.01em;
    fill: transparent;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    /* large enough to cover the longest contour of "VinSong" in Great Vibes */
    stroke-dasharray: 1400;
    stroke-dashoffset: 1400;
    animation:
      about-signature-draw 1s cubic-bezier(0.65, 0, 0.35, 1) 0.2s forwards,
      about-signature-fill 0.35s ease-out 1.15s forwards;
  }
  @keyframes about-signature-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes about-signature-fill {
    to {
      fill: currentColor;
    }
  }

  /* Iridescent-ink layer, revealed through a cursor-following radial mask. */
  .about-signature-glow-svg {
    /* blue iridescent ink-glow removed per request */
    display: none;
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.45s ease-out;
    pointer-events: none;
    filter: drop-shadow(0 0 10px hsl(193 60% 75% / 0.35));
    -webkit-mask-image: radial-gradient(
      circle 150px at var(--mx, 50%) var(--my, 50%),
      #000 30%,
      transparent 78%
    );
    mask-image: radial-gradient(
      circle 150px at var(--mx, 50%) var(--my, 50%),
      #000 30%,
      transparent 78%
    );
  }
  .about-signature-glow-svg.glow-on {
    opacity: 1;
  }
  .about-signature-glow-text {
    fill: url(#sig-ink-about);
    fill-opacity: 0;
    stroke: url(#sig-ink-about);
    stroke-width: 1.7;
    animation:
      about-signature-draw 1s cubic-bezier(0.65, 0, 0.35, 1) 0.2s forwards,
      about-signature-glow-fill 0.35s ease-out 1.15s forwards;
  }
  @keyframes about-signature-glow-fill {
    to {
      fill-opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-signature-text {
      animation: none;
      fill: currentColor;
      stroke-dashoffset: 0;
    }
  }
</style>
