---
import PageLayout from '@/layouts/CommonPage.astro'
import PDFCard from '@/components/PDFCard.astro'

export const prerender = true

const notes = [
  {
    title: 'Algorithm Design and Analysis',
    subtitle: '演算法設計與分析 呂學一 教授',
    href: '/pdf/ADA_cut.pdf',
    imageSrc: '/images/ADA.png'
  },
  {
    title: 'Linear Algebra',
    subtitle: '線性代數 李明穗 教授',
    href: '/pdf/LinearAlgebra.pdf',
    imageSrc: '/images/LinearAlgebra.png'
  },
  {
    title: 'Introduction to Computation Theory',
    subtitle: '自動機與形式語言 林智仁 教授',
    href: '/pdf/IntroComputation.pdf',
    imageSrc: '/images/IntroComputation.png'
  },
  {
    title: 'System Programming',
    subtitle: '系統程式設計 鄭卜壬 教授',
    href: '/notes/sp',
    imageSrc: '/images/sp.png',
    type: 'note' as const
  }
]
---

<PageLayout title='Note'>
  <p class='text-muted-foreground'>
    這裡放一些我修課時整理的筆記，點擊卡片即可開啟。
  </p>

  <div class='not-prose mt-6 grid grid-cols-1 gap-6 lg:grid-cols-2' data-reveal>
    {notes.map((note) => <PDFCard {...note} />)}
  </div>
</PageLayout>
